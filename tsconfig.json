{
  // Migração TS concluída (SPEC-012). Toda a fonte do framework é .ts, checkJs cobre o que sobra.
  // noImplicitAny está ON: o ratchet está armado — todo parâmetro novo precisa de tipo explícito.
  // Os ~285 params existentes foram anotados na Fase 2 (tipo real onde agrega, `any` explícito onde
  // o valor é genuinamente dinâmico: args de CLI, linhas de SQLite, JSON de payload).
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    // Fase 2: fonte importa ./x.ts (nodenext exige extensão; Node roda .ts nativo em dev).
    // No build vira false + rewriteRelativeImportExtensions reescreve .ts→.js (tsconfig.build.json).
    "allowImportingTsExtensions": true,
    "strict": true,
    "noImplicitAny": true,
    // On-ramp: catch-var como `any` (comportamento pré-TS-4.4). O valor da migração são os
    // contratos tipados (checks/registry/handoff), não estreitar cada catch de script folha.
    // lib/core já estreita explicitamente via asErrno onde importa. Revisitar na Fase 2.
    "useUnknownInCatchVariables": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["lib/**/*", "scripts/**/*", "bin/**/*"],
  "exclude": ["node_modules", "dist", "docs/archive", "lib/templates"]
}
