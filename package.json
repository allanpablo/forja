{
  "name": "forjajs",
  "version": "1.1.3",
  "description": "Forja — framework CLI-first de orquestração multiagente, memória hierárquica e geração de projetos com IA",
  "type": "module",
  "main": "index.js",
  "bin": {
    "forja": "bin/forja.mjs",
    "init-project": "bin/init-project.js",
    "create-memory-nest-kit": "bin/create-memory-nest-kit.js"
  },
  "files": [
    "bin/",
    "lib/",
    "scripts/",
    "prompts/",
    "boilerplates/",
    "design-md/",
    "memory/",
    "docs/",
    "specs/",
    ".claude/agents/",
    ".claude/skills/",
    ".claude/settings.json",
    ".gemini-instructions.md",
    ".openai-instructions.md",
    ".github/copilot-instructions.md",
    ".memoryrc.json",
    "AGENTS.md",
    "DOC-MAP.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "!docs/dashboard.md",
    "!specs/agent-dashboard/"
  ],
  "scripts": {
    "forja": "node bin/forja.mjs",
    "sync:universal": "node bin/forja.mjs sync:universal",
    "query:universal": "node bin/forja.mjs query:universal",
    "dev": "node scripts/dev.mjs",
    "init:project": "node bin/forja.mjs init:project",
    "sprint:start": "node bin/forja.mjs sprint:start",
    "sprint:status": "node bin/forja.mjs sprint:status",
    "sprint:complete": "node bin/forja.mjs sprint:complete",
    "context:smart": "node bin/forja.mjs context:smart",
    "memory:compress": "node bin/forja.mjs memory:compress",
    "memory:vacuum": "node bin/forja.mjs memory:vacuum",
    "memory:schema": "node bin/forja.mjs memory:schema",
    "memory:extract": "node bin/forja.mjs memory:extract",
    "project:check": "node bin/forja.mjs project:check",
    "project:dashboard": "node bin/forja.mjs project:dashboard",
    "context:budget": "node bin/forja.mjs context:budget",
    "context:sprint": "node bin/forja.mjs context:sprint",
    "agent:brief": "node bin/forja.mjs agent:brief",
    "catalog:assets": "node bin/forja.mjs catalog:assets",
    "catalog:manifests": "node bin/forja.mjs catalog:manifests",
    "token:benchmark": "node bin/forja.mjs token:benchmark",
    "spec:new": "node bin/forja.mjs spec:new",
    "spec:plan": "node bin/forja.mjs spec:plan",
    "spec:tasks": "node bin/forja.mjs spec:tasks",
    "spec:check": "node bin/forja.mjs spec:check",
    "agent:route": "node bin/forja.mjs agent:route",
    "workspace:init": "node bin/forja.mjs workspace:init",
    "project:new": "node bin/forja.mjs project:new",
    "project:list": "node bin/forja.mjs project:list",
    "workspace:project:check": "node bin/forja.mjs workspace:project:check",
    "hermes:handoff": "node bin/forja.mjs hermes:handoff",
    "gsd:plan": "node bin/forja.mjs gsd:plan",
    "gsd:handoff": "node bin/forja.mjs gsd:handoff",
    "gsd:check": "node bin/forja.mjs gsd:check",
    "design:check": "node bin/forja.mjs design:check",
    "design:select": "node bin/forja.mjs design:select",
    "ops:plan": "node bin/forja.mjs gsd:plan",
    "ops:handoff": "node bin/forja.mjs gsd:handoff",
    "ops:check": "node bin/forja.mjs gsd:check",
    "ops:sprint": "node bin/forja.mjs sprint:status",
    "code:index": "node bin/forja.mjs code:index",
    "code:sync": "node bin/forja.mjs code:sync",
    "code:status": "node bin/forja.mjs code:status",
    "code:query": "node bin/forja.mjs code:query",
    "code:check": "node bin/forja.mjs code:check",
    "code:impact": "node bin/forja.mjs code:impact",
    "tools:doctor": "node bin/forja.mjs tools:doctor",
    "release:check": "node bin/forja.mjs release:check",
    "test": "node --test test/*.test.js"
  },
  "keywords": [
    "agents",
    "orchestration",
    "memory",
    "sqlite",
    "sdd"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/allanpablo/forja.git"
  },
  "author": "Allan Pablo",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.11.1"
  }
}
