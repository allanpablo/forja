{
  "name": "forjajs",
  "version": "1.3.2",
  "description": "Forja — framework CLI-first de orquestração multiagente, memória hierárquica e geração de projetos com IA",
  "type": "module",
  "main": "index.js",
  "bin": {
    "forja": "dist/bin/forja.js",
    "init-project": "dist/bin/init-project.js",
    "create-memory-nest-kit": "dist/bin/create-memory-nest-kit.js"
  },
  "files": [
    "dist/",
    "prompts/",
    "boilerplates/",
    "design-md/",
    "memory/",
    "docs/",
    "specs/",
    ".claude/agents/",
    ".claude/skills/",
    ".claude/settings.json",
    ".gemini-instructions.md",
    ".openai-instructions.md",
    ".github/copilot-instructions.md",
    ".memoryrc.json",
    "AGENTS.md",
    "README.en.md",
    "DOC-MAP.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "!docs/dashboard.md",
    "!specs/agent-dashboard/"
  ],
  "scripts": {
    "//prepublishOnly": "Gate do tarball (ADR-0024). NUNCA mova para prepack: o gate roda `npm pack`, e o prepack o dispararia de novo — recursão infinita. npm pack não dispara prepublishOnly, e é por isso que ele é o único hook seguro aqui.",
    "prepublishOnly": "node bin/forja.ts release:check -- --publish",
    "forja": "node bin/forja.ts",
    "sync:universal": "node bin/forja.ts sync:universal",
    "query:universal": "node bin/forja.ts query:universal",
    "dev": "node scripts/dev.ts",
    "init:project": "node bin/forja.ts init:project",
    "sprint:start": "node bin/forja.ts sprint:start",
    "sprint:status": "node bin/forja.ts sprint:status",
    "sprint:complete": "node bin/forja.ts sprint:complete",
    "context:smart": "node bin/forja.ts context:smart",
    "memory:compress": "node bin/forja.ts memory:compress",
    "memory:vacuum": "node bin/forja.ts memory:vacuum",
    "memory:schema": "node bin/forja.ts memory:schema",
    "memory:extract": "node bin/forja.ts memory:extract",
    "project:check": "node bin/forja.ts project:check",
    "project:dashboard": "node bin/forja.ts project:dashboard",
    "context:budget": "node bin/forja.ts context:budget",
    "context:sprint": "node bin/forja.ts context:sprint",
    "agent:brief": "node bin/forja.ts agent:brief",
    "catalog:assets": "node bin/forja.ts catalog:assets",
    "catalog:manifests": "node bin/forja.ts catalog:manifests",
    "token:benchmark": "node bin/forja.ts token:benchmark",
    "spec:new": "node bin/forja.ts spec:new",
    "spec:plan": "node bin/forja.ts spec:plan",
    "spec:tasks": "node bin/forja.ts spec:tasks",
    "spec:check": "node bin/forja.ts spec:check",
    "agent:route": "node bin/forja.ts agent:route",
    "workspace:init": "node bin/forja.ts workspace:init",
    "project:new": "node bin/forja.ts project:new",
    "project:list": "node bin/forja.ts project:list",
    "workspace:project:check": "node bin/forja.ts workspace:project:check",
    "hermes:handoff": "node bin/forja.ts hermes:handoff",
    "gsd:plan": "node bin/forja.ts gsd:plan",
    "gsd:handoff": "node bin/forja.ts gsd:handoff",
    "gsd:check": "node bin/forja.ts gsd:check",
    "design:check": "node bin/forja.ts design:check",
    "design:select": "node bin/forja.ts design:select",
    "ops:plan": "node bin/forja.ts gsd:plan",
    "ops:handoff": "node bin/forja.ts gsd:handoff",
    "ops:check": "node bin/forja.ts gsd:check",
    "ops:sprint": "node bin/forja.ts sprint:status",
    "code:index": "node bin/forja.ts code:index",
    "code:sync": "node bin/forja.ts code:sync",
    "code:status": "node bin/forja.ts code:status",
    "code:query": "node bin/forja.ts code:query",
    "code:check": "node bin/forja.ts code:check",
    "code:impact": "node bin/forja.ts code:impact",
    "tools:doctor": "node bin/forja.ts tools:doctor",
    "release:check": "node bin/forja.ts release:check",
    "build": "tsc -p tsconfig.build.json",
    "types:check": "tsc --noEmit",
    "test": "node --test test/*.test.js"
  },
  "keywords": [
    "agents",
    "orchestration",
    "memory",
    "sqlite",
    "sdd"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/allanpablo/forja.git"
  },
  "author": "Allan Pablo",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.11.1"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.9.3"
  }
}
