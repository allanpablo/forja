{
  "schemaVersion": "1.0",
  "type": "boilerplate",
  "name": "04-microservices-starter",
  "title": "🚀 Microservices Starter Kit",
  "path": "boilerplates/04-microservices-starter",
  "readme": "boilerplates/04-microservices-starter/README.md",
  "stack": [
    "NestJS",
    "Docker",
    "RabbitMQ",
    "JWT",
    "Postgres"
  ],
  "useCases": [
    "Monorepo",
    "Admin",
    "Auth"
  ],
  "commands": [
    "npm install",
    "docker compose up -d",
    "npm test"
  ],
  "gates": [
    "npm run spec:check",
    "npm test",
    "npm run project:check"
  ],
  "tokenPolicy": {
    "firstRead": [
      "boilerplate.manifest.json",
      "README.md"
    ],
    "avoidLoadingByDefault": [
      "node_modules",
      "dist",
      "coverage"
    ]
  }
}
