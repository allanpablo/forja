# Environment configuration example
# Copy to .env and modify as needed

NODE_ENV=development

# Auth Service
JWT_SECRET=super-secret-key-change-in-production
AUTH_SERVICE_PORT=3001

# User Service
USER_SERVICE_PORT=3002

# Notification Service
NOTIFICATION_SERVICE_PORT=3003

# API Gateway
API_GATEWAY_PORT=3000

# PostgreSQL Auth
POSTGRES_AUTH_HOST=postgres-auth
POSTGRES_AUTH_PORT=5432
POSTGRES_AUTH_USER=postgres
POSTGRES_AUTH_PASSWORD=password
POSTGRES_AUTH_DB=auth_db

# PostgreSQL User
POSTGRES_USER_HOST=postgres-user
POSTGRES_USER_PORT=5432
POSTGRES_USER_USER=postgres
POSTGRES_USER_PASSWORD=password
POSTGRES_USER_DB=users_db

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
